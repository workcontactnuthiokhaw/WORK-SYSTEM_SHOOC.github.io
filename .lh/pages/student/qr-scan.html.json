opbar-user-name\">นักเรียน</div>\r\n              <div class=\"topbar-user-role\" id=\"topbar-user-role\">Student</div>\r\n            </div>\r\n          </div>\r\n          <button class=\"btn btn-icon\" id=\"logout-btn\" aria-label=\"ออกจากระบบ\"><i class=\"fi fi-rr-sign-out-alt\"></i></button>\r\n        </div>\r\n      </header>\r\n\r\n      <main class=\"app-content\">\r\n        <div class=\"page-header\">\r\n          <div>\r\n            <div class=\"page-header-title\">สแกน QR เพื่อเช็กชื่อ</div>\r\n            <div class=\"page-header-subtitle\">ส่องกล้องไปที่ QR Code ของกิจกรรมที่หน้างานเพื่อบันทึกการเข้าร่วม</div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"qr-scan-wrap\">\r\n          <div class=\"qr-scan-viewport\">\r\n            <video id=\"qr-video\" playsinline></video>\r\n            <div class=\"qr-scan-frame\"></div>\r\n          </div>\r\n          <canvas id=\"qr-canvas\" class=\"is-hidden\"></canvas>\r\n\r\n          <button class=\"btn btn-primary btn-block\" id=\"btn-start-scan\"><i class=\"fi fi-rr-camera\"></i> เปิดกล้องเพื่อสแกน</button>\r\n          <p class=\"qr-scan-status\" id=\"qr-scan-status\">\r\n            กดปุ่มด้านบนเพื่อเริ่มสแกน QR Code ของกิจกรรม\r\n          </p>\r\n        </div>\r\n      </main>\r\n    </div>\r\n  </div>\r\n\r\n  <script type=\"module\">\r\n    import '../../js/auth/logout.js';\r\n    import '../../js/shared/layout.js';\r\n    import '../../js/student/qr-scan.js';\r\n  </script>\r\n</body>\r\n</html>"
