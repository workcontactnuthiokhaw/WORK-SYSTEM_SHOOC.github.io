            "content": "<!DOCTYPE html>\r\n<html lang=\"th\">\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>สแกน QR เช็กชื่อ | Rmutr School - SAMS</title>\r\n\r\n  <link rel=\"stylesheet\" href=\"https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css\" />\r\n\r\n  <link rel=\"stylesheet\" href=\"/css/base/reset.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/base/variables.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/base/typography.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/layout/sidebar.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/layout/topbar.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/layout/dashboard-layout.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/buttons.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/loading.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/popup.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/pages/student.css\" />\r\n\r\n  <!-- Library สแกน QR (ใช้โดย js/student/qr-scan.js) -->\r\n  <script src=\"https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js\"></script>\r\n</head>\r\n<body>\r\n\r\n  <div class=\"app-shell\" id=\"app-shell\">\r\n\r\n    <aside class=\"sidebar\" id=\"sidebar\">\r\n      <div class=\"sidebar-logo\">\r\n        <svg class=\"sidebar-logo-mark\" viewBox=\"0 0 40 40\" xmlns=\"http://www.w3.org/2000/svg\">\r\n          <rect width=\"40\" height=\"40\" rx=\"8\" fill=\"#C8102E\"/>\r\n          <path d=\"M20 10 L24 18 L33 19 L26 25 L28 34 L20 29 L12 34 L14 25 L7 19 L16 18 Z\" fill=\"#fff\"/>\r\n        </svg>\r\n        <div class=\"sidebar-logo-text\">Rmutr School<small>School Activity Management</small></div>\r\n      </div>\r\n\r\n      <nav class=\"sidebar-nav\">\r\n        <div class=\"sidebar-section-label\">กิจกรรมของฉัน</div>\r\n        <a href=\"./activities-list.html\" class=\"sidebar-link\"><i class=\"fi fi-rr-calenda