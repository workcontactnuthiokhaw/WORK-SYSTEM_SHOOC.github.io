            "content": "<!DOCTYPE html>\r\n<html lang=\"th\">\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>รายละเอียดกิจกรรม | Rmutr School - SAMS</title>\r\n\r\n  <link rel=\"stylesheet\" href=\"https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css\" />\r\n\r\n  <link rel=\"stylesheet\" href=\"/css/base/reset.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/base/variables.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/base/typography.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/layout/sidebar.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/layout/topbar.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/layout/dashboard-layout.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/buttons.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/table.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/badge.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/loading.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/empty-state.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/popup.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/pages/teacher.css\" />\r\n</head>\r\n<body>\r\n\r\n  <div class=\"app-shell\" id=\"app-shell\">\r\n\r\n    <aside class=\"sidebar\" id=\"sidebar\">\r\n      <div class=\"sidebar-logo\">\r\n        <svg class=\"sidebar-logo-mark\" viewBox=\"0 0 40 40\" xmlns=\"http://www.w3.org/2000/svg\">\r\n          <rect width=\"40\" height=\"40\" rx=\"8\" fill=\"#C8102E\"/>\r\n          <path d=\"M20 10 L24 18 L33 19 L26 25 L28 34 L20 29 L12 34 L14 25 L7 19 L16 18 Z\" fill=\"#fff\"/>\r\n        </svg>\r\n        <div class=\"sidebar-logo-text\">Rmutr School<small>School Activity Management</small></div>\r\n      </div>\r\n\r\n      <nav class=\"sidebar-nav\">\r\n        <div class=\"sidebar-section-label admin-only\">ผู้ดูแลระบบ</div>\r\n        <a href=\"../admin/users.html\" class=\"sidebar-link admin-only\"><i class=\"fi fi-rr-users\"></i><span>จัดการผู้ใช้งาน</span></a>\r\n        <a href=\"../admin/roles.html\" class=\"sidebar-link admin-only\"><i class=\"fi fi-rr-shield-check\"></i><span>จัดการสิทธิ์</span></a>\r\n        <a href=\"../admin/activity-types.html\" class=\"sidebar-link admin-only\"><i class=\"fi fi-rr-tags\"></i><span>ประเภทกิจกรรม</span></a>\r\n        <a href=\"../admin/academic-years.html\" class=\"sidebar-link admin-only\"><i class=\"fi fi-rr-calendar-lines\"></i><span>ปีการศึกษา</span></a>\r\n        <a href=\"../admin/departments.html\" class=\"sidebar-link admin-only\"><i class=\"fi fi-rr-building\"></i><span>ภาควิชา/แผนก</span></a>\r\n        <a href=\"../admin/classes.html\" class=\"sidebar-link admin-only\"><i class=\"fi fi-rr-chalkboard\"></i><span>ห้องเรียน</span></a>\r\n        <a href=\"../admin/system-logs.html\" class=\"sidebar-link admin-only\"><i class=\"fi fi-rr-time-past\"></i><span>System Logs</span></a>\r\n\r\n        <div class=\"sidebar-section-label teacher-only\">ครู</div>\r\n        <a href=\"./activities.html\" class=\"sidebar-link teacher-only is-active\"><i class=\"fi fi-rr-calendar-star\"></i><span>กิจกรรมทั้งหมด</span></a>\r\n\r\n        <div class=\"sidebar-section-label\">รายงาน</div>\r\n        <a href=\"../reports/dashboard-report.html\" class=\"sidebar-link\"><i class=\"fi fi-rr-dashboard\"></i><span>Dashboard</span></a>\r\n        <a href=\"../reports/activity-report.html\" class=\"sidebar-link teacher-only\"><i class=\"fi fi-rr-document\"></i><span>รายงานกิจกรรม</span></a>\r\n        <a href=\"../reports/student-report.html\" class=\"sidebar-link teacher-only\"><i class=\"fi fi-rr-graduation-cap\"></i><span>รายงานนักเรียน</span></a>\r\n        <a href=\"../reports/score-hours-report.html\" class=\"sidebar-link teacher-only\"><i class=\"fi fi-rr-clock\"></i><span>รายงานคะแนน/ชั่วโมง</span></a>\r\n      </nav>\r\n\r\n      <div class=\"sidebar-footer\">\r\n        <button class=\"sidebar-collapse-btn\" id=\"sidebar-collapse-btn\"><i class=\"fi fi-rr-angle-double-left\"></i><span>ย่อเมนู</span></button>\r\n      </div>\r\n    </aside>\r\n\r\n    <div class=\"sidebar-backdrop\" id=\"sidebar-backdrop\"></div>\r\n\r\n    <div class=\"app-main\">\r\n      <header class=\"topbar\">\r\n        <div class=\"topbar-left\">\r\n          <button class=\"topbar-menu-btn\" id=\"topbar-menu-btn\" aria-label=\"เปิดเมนู\"><i class=\"fi fi-rr-menu-burger\"></i></button>\r\n          <div class=\"topbar-page-title\">รายละเอียดกิจกรรม</div>\r\n        </div>\r\n        <div class=\"topbar-right\">\r\n          <button class=\"topbar-icon-btn\" aria-label=\"แจ้งเตือน\"><i class=\"fi fi-rr-bell\"></i><span class=\"badge-dot\"></span></button>\r\n          <div class=\"topbar-user\">\r\n            <div class=\"topbar-user-avatar\" id=\"topbar-user-avatar\">ค</div>\r\n            <div class=\"topbar-user-info\">\r\n              <div class=\"topbar-user-name\" id=\"topbar-user-name\">ครู</div>\r\n              <div class=\"topbar-user-role\" id=\"topbar-user-role\">Teacher</div>\r\n            </div>\r\n          </div>\r\n          <button class=\"btn btn-icon\" id=\"logout-btn\" aria-label=\"ออกจากระบบ\"><i class=\"fi fi-rr-sign-out-alt\"></i></button>\r\n        </div>\r\n      </header>\r\n\r\n      <main class=\"app-content\">\r\n        <div class=\"page-header\">\r\n          <div>\r\n            <div class=\"page-header-title\" id=\"activity-title\">รายละเอียดกิจกรรม</div>\r\n            <div class=\"activity-card-meta mt-2\" id=\"activity-meta\"></div>\r\n            <div class=\"mt-2\" id=\"activity-status-badge\"></div>\r\n          </div>\r\n          <div class=\"page-header-actions\">\r\n            <button class=\"btn btn-secondary\" id=\"btn-edit-activity\"><i class=\"fi fi-rr-edit\"></i> แก้ไข</button>\r\n            <button class=\"btn btn-secondary\" id=\"btn-manage-teachers\"><i class=\"fi fi-rr-users\"></i> ครูผู้รับผิดชอบ</button>\r\n            <button class=\"btn btn-secondary\" id=\"btn-generate-qr\"><i class=\"fi fi-rr-qrcode\"></i> QR Code</button>\r\n            <button class=\"btn btn-primary\" id=\"btn-attendance\"><i class=\"fi fi-rr-clipboard-check\"></i> เช็กชื่อ/ให้คะแนน</button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"table-card\">\r\n          <div class=\"table-toolbar\">\r\n            <h3>รายชื่อนักเรียนที่ลงทะเบียน</h3>\r\n            <select id=\"filter-registration-status\">\r\n              <option value=\"\">ทุกสถานะ</option>\r\n              <option value=\"pending_approval\">รอการอนุมัติ</option>\r\n              <option value=\"approved\">อนุมัติแล้ว</option>\r\n              <option value=\"registered\">ลงทะเบียนแล้ว</option>\r\n              <option value=\"rejected\">ถูกปฏิเสธ</option>\r\n              <option value=\"cancelled\">ยกเลิกแล้ว</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"table-scroll\">\r\n            <table class=\"data-table\">\r\n              <thead>\r\n                <tr>\r\n                  <th>รหัสนักเรียน</th>\r\n                  <th>ชื่อ-สกุล</th>\r\n                  <th>ห้องเรียน</th>\r\n                  <th>สถานะ</th>\r\n                  <th class=\"text-right\">จัดการ</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody id=\"registration-table-body\"></tbody>\r\n            </table>\r\n          </div>\r\n          <div id=\"loading-state\" class=\"is-hidden loading-inline\">\r\n            <div class=\"spinner\"></div>\r\n          </div>\r\n          <div id=\"empty-state\" class=\"empty-state is-hidden\">\r\n            <div class=\"empty-state-icon\"><i class=\"fi fi-rr-users\"></i></div>\r\n            <div class=\"empty-state-title\">ยังไม่มีนักเรียนลงทะเบียน</div>\r\n            <div class=\"empty-state-message\">รอนักเรียนลงทะเบียนเข้าร่วมกิจกรรมนี้</div>\r\n          </div>\r\n        </div>\r\n      </main>\r\n    </div>\r\n  </div>\r\n\r\n  <script type=\"module\">\r\n    import '../../js/auth/logout.js';\r\n    import '../../js/shared/layout.js';\r\n    import '../../js/teacher/activity-detail.js';\r\n  </script>\r\n</body>\r\n</html>"
