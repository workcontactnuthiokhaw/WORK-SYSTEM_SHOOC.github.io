                    "content": "Index: \n===================================================================\n--- \n+++ \n@@ -12,13 +12,13 @@\n   <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap\" />\r\n \r\n   <link rel=\"stylesheet\" href=\"https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css\" />\r\n \r\n-  <link rel=\"stylesheet\" href=\"css/base/reset.css\" />\r\n-  <link rel=\"stylesheet\" href=\"css/base/variables.css\" />\r\n-  <link rel=\"stylesheet\" href=\"css/base/typography.css\" />\r\n-  <link rel=\"stylesheet\" href=\"css/components/popup.css\" />\r\n-  <link rel=\"stylesheet\" href=\"css/pages/login.css\" />\r\n+  <link rel=\"stylesheet\" href=\"/css/base/reset.css\" />\r\n+  <link rel=\"stylesheet\" href=\"/css/base/variables.css\" />\r\n+  <link rel=\"stylesheet\" href=\"/css/base/typography.css\" />\r\n+  <link rel=\"stylesheet\" href=\"/css/components/popup.css\" />\r\n+  <link rel=\"stylesheet\" href=\"/css/pages/login.css\" />\r\n </head>\r\n <body>\r\n \r\n   <main class=\"login-page\">\r\n@@ -137,7 +137,33 @@\n       toggleBtn.innerHTML = isPassword\r\n         ? '<i class=\"fi fi-rr-eye-crossed\"></i>'\r\n         : '<i class=\"fi fi-rr-eye\"></i>';\r\n     });\r\n+\r\n+    // ---------- จำกัดตัวอักษรที่พิมพ์ได้ ----------\r\n+    // ช่องอีเมล: พิมพ์ได้แค่ตัวอักษรอังกฤษ (a-z, A-Z), ตัวเลข, @ และ .\r\n+    function restrictEmailInput(input) {\r\n+      if (!input) return;\r\n+      input.addEventListener('input', () => {\r\n+        const cleaned = input.value.replace(/[^a-zA-Z0-9@._-]/g, '');\r\n+        if (cleaned !== input.value) input.value = cleaned;\r\n+      });\r\n+    }\r\n+\r\n+    // ช่องรหัสผ่าน: พิมพ์ได้แค่ตัวอักษรอังกฤษ, ตัวเลข, และอักขระพิเศษทั่วไป (ห้ามภาษาไทย/ภาษาอื่น)\r\n+    function restrictPasswordInput(input) {\r\n+      if (!input) return;\r\n+      input.addEventListener('input', () => {\r\n+        const cleaned = input.value.replace(/[^a-zA-Z0-9!@#$%^&*()_+\\-=[\\]{};':\"\\\\|,.<>/?~`]/g, '');\r\n+        if (cleaned !== input.value) input.value = cleaned;\r\n+      });\r\n+    }\r\n+\r\n+    // ใช้กับทุกช่องอีเมล/รหัสผ่านในหน้านี้ (login, reset, ตั้งรหัสผ่านใหม่)\r\n+    restrictEmailInput(document.getElementById('login-email'));\r\n+    restrictEmailInput(document.getElementById('reset-email'));\r\n+    restrictPasswordInput(document.getElementById('login-password'));\r\n+    restrictPasswordInput(document.getElementById('new-password'));\r\n+    restrictPasswordInput(document.getElementById('new-password-confirm'));\r\n   </script>\r\n </body>\r\n </html>\n\\ No newline at end of file\n"
                }
