            "date": 1783578832918,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"th\">\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>เข้าสู่ระบบ | Rmutr School - SAMS</title>\r\n\r\n  <!-- Flaticon Uicons (ไอคอนทั้งระบบใช้ตัวนี้ตัวเดียว ห้ามใช้ icon library อื่น) -->\r\n  <link rel=\"stylesheet\" href=\"https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css\" />\r\n\r\n  <link rel=\"stylesheet\" href=\"/css/base/reset.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/base/variables.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/base/typography.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/components/popup.css\" />\r\n  <link rel=\"stylesheet\" href=\"/css/pages/login.css\" />\r\n</head>\r\n<body>\r\n\r\n  <main class=\"login-page\">\r\n    <div class=\"login-card\">\r\n\r\n      <!-- ฝั่งซ้าย: แบรนด์ -->\r\n      <section class=\"login-brand\">\r\n        <div>\r\n          <svg class=\"login-brand-seal\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n            <circle cx=\"50\" cy=\"50\" r=\"46\" fill=\"none\" stroke=\"#ffffff\" stroke-opacity=\"0.9\" stroke-width=\"3\"/>\r\n            <circle cx=\"50\" cy=\"50\" r=\"36\" fill=\"none\" stroke=\"#ffffff\" stroke-opacity=\"0.55\" stroke-width=\"1.5\" stroke-dasharray=\"2 4\"/>\r\n            <path d=\"M50 30 L58 46 L76 48 L63 60 L66 78 L50 69 L34 78 L37 60 L24 48 L42 46 Z\" fill=\"#ffffff\" fill-opacity=\"0.95\"/>\r\n          </svg>\r\n          <div class=\"login-brand-copy\">\r\n            <h1>Rmutr School</h1>\r\n            <p>ระบบจัดการกิจกรรมสถานศึกษา ลงทะเบียน เช็กชื่อด้วย QR สะสมชั่วโมง และรับใบประกาศนียบัตรในที่เดียว</p>\r\n          </div>\r\n        </div>\r\n        <div class=\"login-brand-footer\">School Activity Management System</div>\r\n      </section>\r\n\r\n      <!-- ฝั่งขวา: ฟอร์ม login -->\r\n      <section class=\"login-form-panel\" id=\"login-panel\">\r\n        <h2 class=\"login-form-title\">เข้าสู่ระบบ</h2>\r\n        <p class=\"login-form-subtitle\">กรอกอีเมลและรหัสผ่านของคุณเพื่อเข้าใช้งานระบบ</p>\r\n\r\n        <form id=\"login-form\" novalidate>\r\n          <div class=\"login-field\">\r\n            <label for=\"login-email\">อีเมล</label>\r\n            <div class=\"login-input-wrap\">\r\n              <i class=\"fi fi-rr-envelope\"></i>\r\n              <input type=\"email\" id=\"login-email\" name=\"email\" placeholder=\"you@example.com\" autocomplete=\"username\" required />\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"login-field\">\r\n            <label for=\"login-password\">รหัสผ่าน</label>\r\n            <div class=\"login-input-wrap\">\r\n              <i class=\"fi fi-rr-lock\"></i>\r\n              <input type=\"password\" id=\"login-password\" name=\"password\" placeholder=\"••••••••\" autocomplete=\"current-password\" required />\r\n              <button type=\"button\" class=\"login-toggle-visibility\" id=\"toggle-password\" aria-label=\"แสดง/ซ่อนรหัสผ่าน\">\r\n                <i class=\"fi fi-rr-eye\"></i>\r\n              </button>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"login-row-between\">\r\n            <a href=\"#\" class=\"login-link\" id=\"login-forgot-link\">ลืมรหัสผ่าน?</a>\r\n          </div>\r\n\r\n          <button type=\"submit\" class=\"login-submit-btn\" id=\"login-submit\">เข้าสู่ระบบ</button>\r\n        </form>\r\n      </section>\r\n\r\n      <!-- ฝั่งขวา: ฟอร์มขอลิงก์รีเซ็ตรหัสผ่าน (ซ่อนไว้ก่อน) -->\r\n      <section class=\"login-form-panel is-hidden\" id=\"reset-panel\">\r\n        <h2 class=\"login-form-title\">ลืมรหัสผ่าน</h2>\r\n        <p class=\"login-form-subtitle\">กรอกอีเมลที่ใช้ลงทะเบียน ระบบจะส่งลิงก์ตั้งรหัสผ่านใหม่ให้ทางอีเมล</p>\r\n\r\n        <form id=\"reset-request-form\" novalidate>\r\n          <div class=\"login-field\">\r\n            <label for=\"reset-email\">อีเมล</label>\r\n            <div class=\"login-input-wrap\">\r\n              <i class=\"fi fi-rr-envelope\"></i>\r\n              <input type=\"email\" id=\"reset-email\" name=\"email\" placeholder=\"you@example.com\" required />\r\n            </div>\r\n          </div>\r\n\r\n          <button type=\"submit\" class=\"login-submit-btn\" id=\"reset-submit\">ส่งลิงก์รีเซ็ตรหัสผ่าน</button>\r\n        </form>\r\n\r\n        <div class=\"login-back-row\">\r\n          <a href=\"#\" class=\"login-link\" id=\"back-to-login-link\">กลับไปหน้าเข้าสู่ระบบ</a>\r\n        </div>\r\n      </section>\r\n\r\n      <!-- ฝั่งขวา: ฟอร์มตั้งรหัสผ่านใหม่ (แสดงเมื่อกดลิงก์จากอีเมลกลับมา) -->\r\n      <section class=\"login-form-panel is-hidden\" id=\"new-password-panel\">\r\n        <h2 class=\"login-form-title\">ตั้งรหัสผ่านใหม่</h2>\r\n        <p class=\"login-form-subtitle\">กรอกรหัสผ่านใหม่ของคุณ</p>\r\n\r\n        <form id=\"new-password-form\" novalidate>\r\n          <div class=\"login-field\">\r\n            <label for=\"new-password\">รหัสผ่านใหม่</label>\r\n            <div class=\"login-input-wrap\">\r\n              <i class=\"fi fi-rr-lock\"></i>\r\n              <input type=\"password\" id=\"new-password\" name=\"newPassword\" placeholder=\"อย่างน้อย 6 ตัวอักษร\" required />\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"login-field\">\r\n            <label for=\"new-password-confirm\">ยืนยันรหัสผ่านใหม่</label>\r\n            <div class=\"login-input-wrap\">\r\n              <i class=\"fi fi-rr-lock\"></i>\r\n              <input type=\"password\" id=\"new-password-confirm\" name=\"newPasswordConfirm\" placeholder=\"พิมพ์รหัสผ่านอีกครั้ง\" required />\r\n            </div>\r\n          </div>\r\n\r\n          <button type=\"submit\" class=\"login-submit-btn\">บันทึกรหัสผ่านใหม่</button>\r\n        </form>\r\n      </section>\r\n\r\n    </div>\r\n  </main>\r\n\r\n  <script type=\"module\">\r\n    import './js/auth/login.js';\r\n    import './js/auth/reset-password.js';\r\n\r\n    // ปุ่มแสดง/ซ่อนรหัสผ่าน\r\n    const toggleBtn = document.getElementById('toggle-password');\r\n    const passwordInput = document.getElementById('login-password');\r\n    toggleBtn?.addEventListener('click', () => {\r\n      const isPassword = passwordInput.type === 'password';\r\n      passwordInput.type = isPassword ? 'text' : 'password';\r\n      toggleBtn.innerHTML = isPassword\r\n        ? '<i class=\"fi fi-rr-eye-crossed\"></i>'\r\n        : '<i class=\"fi fi-rr-eye\"></i>';\r\n    });\r\n  </script>\r\n</body>\r\n</html>"
        }
    ]
}